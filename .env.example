# Copy this file to .env for local dev (or set these in the Netlify UI for prod).
# NEVER commit a real .env — it's gitignored.

# --- Supabase (project settings → API) ---
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                  # service_role key — server-only, bypasses RLS

# --- Email (Gmail SMTP via app password on info@anytimeshift.com) ---
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx                           # 16-char Gmail app password (not the account password)

# --- Admin dashboard auth ---
ADMIN_PASSWORD=change-me-to-something-strong
ADMIN_SECRET=change-me-to-32-plus-random-chars-for-cookie-signing
